# Basic
*          text=auto

*.txt      text
*.md       text diff=markdown

LICENSE-*  text
COPYING-*  text

# Web
*.html     text diff=html
*.css      text diff=css
*.js       text

# Graphics
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary

*.svg      text

# Scripts
*.sh       text eol=lf
*.py       text diff=python

# Preserve
*.patch    -text

# Exclude
.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore
